# DATABASE_URL: Required for PostgreSQL / Supabase connection.
DATABASE_URL="YOUR_POSTGRESQL_CONNECTION_STRING"

# GEMMA_API_URL: Hugging Face Inference API endpoint for Gemma 4 31B.
GEMMA_API_URL="https://api-inference.huggingface.co/models/google/gemma-4-31b-it"

# HF_API_TOKEN: Required Hugging Face API Token for Gemma 4 31B inference access.
HF_API_TOKEN="YOUR_HF_API_TOKEN"

# GEMMA_MODEL: Model identifier — locked to Gemma 4 31B for this submission.
GEMMA_MODEL="google/gemma-4-31b-it"

# APP_URL: The URL where this app is hosted (defaults to localhost for local dev).
APP_URL="http://localhost:3000"
