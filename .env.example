# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required for PostgreSQL / Supabase connection.
DATABASE_URL="YOUR_POSTGRESQL_CONNECTION_STRING"

# GEMMA_API_URL: Base URL for a self-hosted Gemma instance or Hugging Face Inference API.
GEMMA_API_URL="https://api-inference.huggingface.co/models/google/gemma-2-27b-it"

# HF_API_TOKEN: Required Hugging Face API Token if using Hugging Face Inference API.
HF_API_TOKEN="YOUR_HF_API_TOKEN"

# GEMMA_MODEL: Model name identifier to use for Gemma.
GEMMA_MODEL="google/gemma-2-27b-it"
